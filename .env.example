# Local: use postgresql+asyncpg://...
# Render: link Postgres — Internal Database URL is set automatically (postgres:// is OK)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/data
GROQ_API_KEY=your_groq_api_key_here
SLOW_QUERY_THRESHOLD_MS=500
GROQ_MODEL=llama-3.3-70b-versatile
ANALYSIS_DEDUP_SECONDS=3600
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
